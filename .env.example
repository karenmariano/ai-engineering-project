# Point at the RAG-optimized pack root (must contain chunks/chunks.jsonl)
RAG_CORPUS_DIR=/Users/karenmariano/Downloads/rag_policy_corpus

# Copy to .env and fill in your real key. Do not commit .env.

# --- LLM (OpenRouter) — https://openrouter.ai/keys ---
# LLM_MODEL must be a real model route from https://openrouter.ai/models
# (there is no model literally named "openrouter/free"; free-tier models usually end in :free)
LLM_API_KEY=your_openrouter_api_key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemma-2-9b-it:free

# Other common free examples: meta-llama/llama-3.2-3b-instruct:free
# OpenAI direct: OPENAI_API_KEY=sk-...  OPENAI_BASE_URL=https://api.openai.com/v1  LLM_MODEL=gpt-4o-mini
# Google Gemini: see README (generativelanguage.googleapis.com OpenAI-compatible endpoint)

# Longer policy answers (optional overrides)
# RAG_MAX_ANSWER_CHARS=12000
# LLM_MAX_TOKENS=2000
# EXTRACTIVE_MAX_CHARS=10000
# CITATION_SNIPPET_MAX_CHARS=2000

# Embedding model for Chroma (Sentence Transformers; Hugging Face name)
# EMBEDDING_MODEL=all-MiniLM-L6-v2
